# QuantumAI-Dockerized-System Environment Template
# Copy to .env and fill mandatory values. Never commit real private keys.

# Core
APP_ROOT=__ABSOLUTE_APP_ROOT__
DATA_BASE=__ABSOLUTE_EXTERNAL_DATA_BASE__
HOST_PORT=8080

# Ethereum / Provider
INFURA_PROJECT_ID=__REQUIRED_INFURA_ID__
ETH_SENDER_ADDRESS=__YOUR_WALLET_ADDRESS__
ETH_PRIVATE_KEY=__YOUR_PRIVATE_KEY__(never commit real key)
RECEIVER_ADDRESS=__RECEIVER_WALLET_ADDRESS__
CHAIN_ID=1

# Model
MODEL_PATH=/modeldata/trained_model.json

# Redis / Cache
REDIS_URL=redis://redis:6379/0
ETHERSCAN_CACHE_TTL=60
DISABLE_CACHE=0

# Gunicorn Tuning
GUNICORN_WORKERS=2
GUNICORN_MAX_REQUESTS=1000
GUNICORN_MAX_REQUESTS_JITTER=50

# Metrics
METRICS_PORT=9100

# Flags
FLASK_DEBUG=0
GLI_DRY_RUN=1

# Placeholder secrets (document only) - never real values
# PRIVATE_KEY=<deprecated, use ETH_PRIVATE_KEY>
