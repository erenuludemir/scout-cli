services:
  app:
    image: alpine:3.20
    command: ["sh", "-c", "echo QuantumAI system up; while :; do sleep 60; done"]
    restart: unless-stopped
    healthcheck:
      test: ["CMD", "sh", "-c", "echo ok"]
      interval: 30s
      timeout: 3s
      retries: 3
      services:
  gli-container:
    image: erenuludemir/gli-app:fixed
    restart: unless-stopped
  gli-mainnet:
    image: erenuludemir/gli-app:fixed
    restart: unless-stopped
  gli-sepolia:
    image: erenuludemir/gli-app:fixed
    restart: unless-stopped
