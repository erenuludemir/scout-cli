### WARNING: Do NOT use or commit real secrets here. Replace with placeholders only.

FLASK_DEBUG=0
PRIVATE_KEY=

# ===== Networking & API =====
NODE_URL=https://mainnet.infura.io/v3/<YOUR_INFURA_PROJECT_ID>
DATABASE_URL=postgresql://qaiuser:qaipass@localhost:5432/qai
HOST_PORT=5003

# ===== Path Abstraction (use env variables or config mounts) =====
# Docker volumes or mount points - defaults to current directory
APP_ROOT=${APP_ROOT:-.}
DATA_BASE=${DATA_BASE:-.}
MODEL_SOURCE_PATH=${MODEL_SOURCE_PATH:-./models/trained_model.json}
MODEL_PATH=${MODEL_PATH:-./models/trained_model.json}

METRICS_PORT=9100

# ===== Etherscan V2 unified key =====
ETHERSCAN_API_KEY=${ETHERSCAN_API_KEY:-CHANGEME}
ETHERSCAN_CHAIN_IDS=1,42161,10,8453

# ===== Legacy explorer endpoint overrides (optional) =====
ETHERSCAN_API_URL=https://api.etherscan.io/api
ARBISCAN_API_URL=https://api.arbiscan.io/api
OPTIMISM_API_URL=https://api-optimistic.etherscan.io/api
BSCSCAN_API_URL=https://api.bscscan.com/api
SNOWSCAN_API_URL=https://api.snowscan.xyz/api

# Optional legacy per-explorer keys
ARBISCAN_API_KEY=${ARBISCAN_API_KEY:-CHANGEME}
OPTIMISM_API_KEY=${OPTIMISM_API_KEY:-CHANGEME}
BSCSCAN_API_KEY=${BSCSCAN_API_KEY:-CHANGEME}
SNOWSCAN_API_KEY=${SNOWSCAN_API_KEY:-CHANGEME}
ETH_ADDRESS=${ETH_ADDRESS:-0x0000000000000000000000000000000000000000}

# ===== Linear.app (placeholders) =====
LINEAR_API_KEY=${LINEAR_API_KEY:-CHANGEME}
LINEAR_API_URL=https://api.linear.app/graphql
LINEAR_API_TIMEOUT=20
LINEAR_TEAM_ID=
LINEAR_TEAM_KEY=
LINEAR_TEAM_NAME=
LINEAR_AUTO_CREATE_ISSUE=0
LINEAR_ISSUE_PRIORITY=0
